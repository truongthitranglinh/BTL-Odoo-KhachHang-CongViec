<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Xu Ly Khieu Nai Form View -->
        <record id="view_xu_ly_khieu_nai_form" model="ir.ui.view">
            <field name="name">xu_ly_khieu_nai.form</field>
            <field name="model">xu_ly_khieu_nai</field>
            <field name="arch" type="xml">
                <form>
                    <header>
                        <button name="action_bat_dau_xu_ly" string="Bắt đầu xử lý" type="object" class="btn-primary" attrs="{'invisible': [('trang_thai', '!=', 'moi')]}"/>
                        <button name="action_phan_hoi" string="Phản hồi" type="object" class="btn-info" attrs="{'invisible': [('trang_thai', '!=', 'dang_xu_ly')]}"/>
                        <button name="action_hoan_thanh" string="Hoàn thành" type="object" class="btn-success" attrs="{'invisible': [('trang_thai', '!=', 'da_phan_hoi')]}"/>
                        <button name="action_tu_choi" string="Từ chối" type="object" class="btn-danger"/>
                        <field name="trang_thai" widget="statusbar"/>
                    </header>
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="tieu_de_khieu_nai" placeholder="Tiêu đề khiếu nại"/>
                            </h1>
                        </div>
                        <group>
                            <group string="Thông tin cơ bản">
                                <field name="ma_khieu_nai"/>
                                <field name="khach_hang_id"/>
                                <field name="loai_khieu_nai"/>
                                <field name="muc_do_uu_tien"/>
                            </group>
                            <group string="Thời gian">
                                <field name="ngay_khieu_nai"/>
                                <field name="ngay_xu_ly"/>
                                <field name="ngay_ket_thuc"/>
                            </group>
                        </group>
                        <group string="Nội dung khiếu nại">
                            <field name="noi_dung_khieu_nai" nolabel="1"/>
                        </group>
                        <group>
                            <group string="Xử lý">
                                <field name="nguoi_xu_ly_id"/>
                                <field name="ket_qua"/>
                            </group>
                            <group string="Bồi thường">
                                <field name="so_tien_boi_thuong"/>
                            </group>
                        </group>
                        <group string="Giải pháp">
                            <field name="giai_phap" nolabel="1"/>
                        </group>
                        <group string="Phản hồi xử lý">
                            <field name="phan_hoi_xu_ly" nolabel="1"/>
                        </group>
                        <group string="Ghi chú">
                            <field name="ghi_chu" nolabel="1"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="view_xu_ly_khieu_nai_tree" model="ir.ui.view">
            <field name="name">xu_ly_khieu_nai.tree</field>
            <field name="model">xu_ly_khieu_nai</field>
            <field name="arch" type="xml">
                <tree decoration-danger="muc_do_uu_tien == 'rat_cao'" decoration-warning="muc_do_uu_tien == 'cao'" decoration-success="trang_thai == 'hoan_thanh'" decoration-muted="trang_thai == 'tu_choi'">
                    <field name="ma_khieu_nai"/>
                    <field name="tieu_de_khieu_nai"/>
                    <field name="khach_hang_id"/>
                    <field name="loai_khieu_nai"/>
                    <field name="muc_do_uu_tien"/>
                    <field name="ngay_khieu_nai"/>
                    <field name="trang_thai"/>
                </tree>
            </field>
        </record>

        <record id="action_xu_ly_khieu_nai" model="ir.actions.act_window">
            <field name="name">Xử lý khiếu nại</field>
            <field name="res_model">xu_ly_khieu_nai</field>
            <field name="view_mode">tree,form</field>
        </record>
    </data>
</odoo>