<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ============ PIVOT: Công việc theo nhân viên & trạng thái ============ -->
    <record id="view_cong_viec_pivot_dashboard" model="ir.ui.view">
        <field name="name">cong_viec.pivot.dashboard</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <pivot string="Thống kê công việc">
                <field name="nguoi_thuc_hien_id" type="row"/>
                <field name="trang_thai" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ============ GRAPH: Công việc theo trạng thái ============ -->
    <record id="view_cong_viec_graph_dashboard" model="ir.ui.view">
        <field name="name">cong_viec.graph.dashboard</field>
        <field name="model">cong_viec</field>
        <field name="arch" type="xml">
            <graph string="Công việc theo trạng thái" type="bar">
                <field name="trang_thai"/>
            </graph>
        </field>
    </record>

    <!-- ============ PIVOT: Khách hàng theo trạng thái & người phụ trách ============ -->
    <record id="view_khach_hang_pivot_dashboard" model="ir.ui.view">
        <field name="name">khach_hang.pivot.dashboard</field>
        <field name="model">khach_hang</field>
        <field name="arch" type="xml">
            <pivot string="Thống kê khách hàng">
                <field name="nguoi_phu_trach_id" type="row"/>
                <field name="trang_thai" type="col"/>
            </pivot>
        </field>
    </record>

    <!-- ============ GRAPH: Khách hàng theo trạng thái ============ -->
    <record id="view_khach_hang_graph_dashboard" model="ir.ui.view">
        <field name="name">khach_hang.graph.dashboard</field>
        <field name="model">khach_hang</field>
        <field name="arch" type="xml">
            <graph string="Khách hàng theo trạng thái" type="bar">
                <field name="trang_thai"/>
            </graph>
        </field>
    </record>

    <!-- ============ ACTIONS ============ -->
    <record id="action_cong_viec_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard Công việc</field>
        <field name="res_model">cong_viec</field>
        <field name="view_mode">pivot,graph</field>
    </record>

    <record id="action_khach_hang_dashboard" model="ir.actions.act_window">
        <field name="name">Dashboard Khách hàng</field>
        <field name="res_model">khach_hang</field>
        <field name="view_mode">pivot,graph</field>
    </record>

    <!-- ============ MENU ============ -->
    <menuitem id="menu_dashboard_root"
        name="Dashboard"
        sequence="1"/>

    <menuitem id="menu_cong_viec_dashboard"
        name="Công việc"
        parent="menu_dashboard_root"
        action="action_cong_viec_dashboard"
        sequence="1"/>

    <menuitem id="menu_khach_hang_dashboard"
        name="Khách hàng"
        parent="menu_dashboard_root"
        action="action_khach_hang_dashboard"
        sequence="2"/>

</odoo>